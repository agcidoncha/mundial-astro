---
export async function getStaticPaths() {
  const res = await fetch(
    "https://v3.football.api-sports.io/standings?league=1&season=2022",
    {
      headers: {
        "x-apisports-key": import.meta.env.API_FOOTBALL_KEY,
      },
    },
  );

  const data = await res.json();
  const allGroups = data.response[0].league.standings;

  return allGroups.map((group) => ({
    params: {
      slug: group[0].group.toLowerCase().replace(" ", "-"),
    },
    props: {
      group,
    },
  }));
}

const { group } = Astro.props;

// FETCH PARTIDOS
const resMatches = await fetch(
  "https://v3.football.api-sports.io/fixtures?league=1&season=2022",
  {
    headers: {
      "x-apisports-key": import.meta.env.API_FOOTBALL_KEY,
    },
  },
);

const dataMatches = await resMatches.json();

// FILTRO
const teamIds = group.map((item) => item.team.id);

const matches = dataMatches.response.filter((m) => {
  const homeId = m.teams.home.id;
  const awayId = m.teams.away.id;

  return teamIds.includes(homeId) && teamIds.includes(awayId);
});

// DEBUG
console.log("grupo actual:", group[0].group);
console.log("equipos del grupo:", teamIds);
console.log("partidos encontrados:", matches.length);
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{group[0].group}</title>
  </head>

  <body>
    <main class="container">
      <a href="/" class="back">← Volver a grupos</a>

      <header class="hero">
        <p class="eyebrow">WORLD CUP 2022</p>
        <h1>{group[0].group}</h1>
        <p class="subtitle">Equipos y clasificación del grupo.</p>
      </header>

      <!-- CLASIFICACIÓN -->
      <section class="card">
        <ul>
          {
            group.map((item) => (
              <li>
                <span class="rank">{item.rank}</span>

                <div class="team">
                  <img src={item.team.logo} alt={item.team.name} />
                  <span>{item.team.name}</span>
                </div>

                <span class="points">{item.points} pts</span>
              </li>
            ))
          }
        </ul>
      </section>

      <!-- PARTIDOS -->
      <section class="card matches">
        <div class="section-heading">
          <p class="eyebrow">MATCHES</p>
          <h2>Partidos del grupo</h2>
        </div>

        <ul>
          {
            matches.map((match) => (
              <li>
                <span>{match.teams.home.name}</span>
                <strong>
                  {match.goals.home} - {match.goals.away}
                </strong>
                <span>{match.teams.away.name}</span>
              </li>
            ))
          }
        </ul>
      </section>
    </main>
  </body>
</html>

<style>
  :global(body) {
    margin: 0;
    font-family: Arial, Helvetica, sans-serif;
    background: #ffffff;
    color: #1d1d1f;
  }

  .container {
    max-width: 900px;
    margin: 0 auto;
    padding: 56px 24px 80px;
  }

  .back {
    display: inline-block;
    margin-bottom: 32px;
    color: inherit;
    text-decoration: none;
    font-size: 0.95rem;
  }

  .hero {
    margin-bottom: 32px;
  }

  .eyebrow {
    margin: 0 0 10px;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 1.6px;
    color: #86868b;
  }

  h1 {
    margin: 0;
    font-size: clamp(2.2rem, 5vw, 4rem);
    line-height: 1.05;
    font-weight: 700;
    letter-spacing: -0.04em;
  }

  .subtitle {
    margin: 14px 0 0;
    font-size: 1.05rem;
    line-height: 1.6;
    color: #6e6e73;
  }

  .card {
    background: #ffffff;
    border-radius: 28px;
    padding: 24px;
    border: 1px solid #f0f0f0;
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.04);
    margin-bottom: 24px;
  }

  ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  li {
    display: grid;
    grid-template-columns: 40px 1fr auto;
    align-items: center;
    gap: 14px;
    padding: 16px 0;
    border-bottom: 1px solid #f2f2f2;
  }

  li:last-child {
    border-bottom: none;
  }

  .rank {
    font-size: 0.95rem;
    font-weight: 700;
    color: #86868b;
  }

  .team {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .points {
    font-weight: 700;
  }

  img {
    width: 28px;
    height: 28px;
  }

  .matches li {
    grid-template-columns: 1fr auto 1fr;
    text-align: center;
  }

  .matches strong {
    font-weight: 700;
  }

  .section-heading {
    margin-bottom: 12px;
  }

  .section-heading .eyebrow {
    margin: 0 0 8px;
  }

  .matches h2 {
    margin: 0;
    font-size: 1.4rem;
    letter-spacing: -0.02em;
  }
</style>
