---
const res = await fetch(
  "https://v3.football.api-sports.io/standings?league=1&season=2022",
  {
    headers: {
      "x-apisports-key": import.meta.env.API_FOOTBALL_KEY,
    },
  },
);

const data = await res.json();

console.log(JSON.stringify(data, null, 2));
const groups = data.response[0].league.standings;
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Proyecto Mundial</title>
  </head>

  <body>
    <main class="container">
      <header class="hero">
        <p class="eyebrow">WORLD CUP</p>
        <h1>Proyecto Mundial</h1>
        <p class="subtitle">
          Grupos del Mundial con diseño limpio, claro y elegante.
        </p>
        <section class="groups">
          {
            groups.map((group) => (
              <article class="card">
                <h2>{group[0].group}</h2>

                <ul>
                  {group.map((item) => (
                    <li>
                      <div class="team">
                        <img src={item.team.logo} alt={item.team.name} />
                        <span>{item.team.name}</span>
                      </div>
                    </li>
                  ))}
                </ul>
              </article>
            ))
          }
        </section>
      </header>
    </main>
  </body>
</html>

<style>
  :global(body) {
    margin: 0;
    font-family: Arial, Helvetica, sans-serif;
    background: #ffffff;
    color: #1d1d1f;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 56px 24px 80px;
  }

  .hero {
    text-align: center;
    margin-bottom: 56px;
  }

  .eyebrow {
    margin: 0 0 10px;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 1.6px;
    color: #86868b;
  }

  h1 {
    margin: 0;
    font-size: clamp(2.4rem, 5vw, 4.5rem);
    line-height: 1.05;
    font-weight: 700;
    letter-spacing: -0.04em;
  }

  .subtitle {
    max-width: 620px;
    margin: 14px auto 0;
    font-size: 1.05rem;
    line-height: 1.6;
    color: #6e6e73;
  }

  .groups {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 24px;
  }

  .card {
    background: #ffffff;
    border-radius: 28px;
    padding: 24px;
    border: 1px solid #f0f0f0;
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.04);
    transition:
      transform 0.25s ease,
      box-shadow 0.25s ease;
  }

  .card:hover {
    transform: translateY(-4px);
    box-shadow: 0 10px 24px rgba(0, 0, 0, 0.08);
  }

  .card h2 {
    margin: 0 0 18px;
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  li {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    padding: 14px 0;
    border-bottom: 1px solid #f2f2f2;
  }

  li:last-child {
    border-bottom: none;
  }

  .team {
    display: flex;
    align-items: center;
    gap: 10px;
    min-width: 0;
  }

  .team span {
    font-size: 0.98rem;
    font-weight: 600;
    color: #1d1d1f;
  }

  .points {
    font-size: 0.92rem;
    font-weight: 600;
    color: #86868b;
    white-space: nowrap;
  }

  img {
    width: 24px;
    height: 24px;
    object-fit: contain;
    flex-shrink: 0;
  }
</style>
